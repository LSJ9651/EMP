DATABASE_URL=sqlite:///./energy_optimizer.db
DEBUG=false
SERVER_PORT=8000
SERVER_HOST=0.0.0.0

# ========== LLM 配置（真实 API Key 仅存于此） ==========
# LLM_API_KEY: 对话模型的 API Key（OpenAI 兼容接口用）
# 留空时降级使用数据库 llm_config 表中的值
LLM_API_KEY=your_llm_api_key
# LLM_EMBEDDING_API_KEY: 嵌入模型的 API Key（OpenAI 兼容接口用）
# 留空时降级使用数据库 llm_config 表中的值
LLM_EMBEDDING_API_KEY=your_embedding_api_key

# ========== Coze 智能体配置 ==========
COZE_API_KEY=your_coze_api_key
COZE_API_BASE=https://api.coze.cn
COZE_ANALYZE_WORKFLOW_ID=your_analyze_workflow_id
COZE_OPTIMIZE_WORKFLOW_ID=your_optimize_workflow_id
COZE_CHAT_BOT_ID=your_chat_bot_id
COZE_AGENT_TIMEOUT=120
COZE_CHAT_TIMEOUT=30
